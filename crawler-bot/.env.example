# ── TataNano Scraper — Environment Config ─────────────────────────────────────
# Copy this file to .env and fill in your values.

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram chat IDs (comma-separated). Leave empty to allow all.
ALLOWED_CHAT_IDS=

# Firecrawl API Key (from app.firecrawl.dev)
FIRECRAWL_API_KEY=fc-your_firecrawl_key_here

# Firecrawl base URL (don't change unless self-hosting)
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Ollama settings (local, no data leaves your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_TIMEOUT=120

# Database path (SQLite)
DB_PATH=./data/scrapenano.db

# Export directory for Excel files
EXPORT_DIR=./exports

# Scraping limits
CRAWL_MAX_PAGES=50
SCRAPE_TIMEOUT=30
RATE_LIMIT_DELAY=1.5
